{{!
    @template mod_confscheduler/grid

    Page shell for the edit-mode drag-and-drop schedule grid. This template
    renders the container and static chrome (toolbar buttons, unscheduled
    panel wrapper) only; all grid data (rooms, slots, unscheduled
    submissions) is fetched via AJAX and rendered into the empty
    .mod_confscheduler-grid / .mod_confscheduler-unscheduled-list containers
    by amd/src/scheduler_grid.js once the page loads.

    Context variables required for this template:
    * cmid int - the confscheduler course-module id
    * confschedulerid int - the confscheduler instance id
    * canmanage bool - whether the current user has mod/confscheduler:manageschedule

    Example context (json):
    {
        "cmid": 5,
        "confschedulerid": 3,
        "canmanage": true
    }
}}
<div id="mod_confscheduler-grid-root"
     class="mod_confscheduler-grid-container"
     data-cmid="{{cmid}}"
     data-confschedulerid="{{confschedulerid}}">
    <div class="mod_confscheduler-toolbar d-flex flex-wrap justify-content-between align-items-center mb-2">
        <div class="mod_confscheduler-toolbar-actions d-flex flex-wrap align-items-center">
            {{#canmanage}}
            <button type="button" class="btn btn-secondary btn-sm mod_confscheduler-add-room">
                {{#str}} addroom, mod_confscheduler {{/str}}
            </button>
            <button type="button" class="btn btn-secondary btn-sm mod_confscheduler-add-spanblock">
                {{#str}} addspanblock, mod_confscheduler {{/str}}
            </button>
            <button type="button" class="btn btn-primary btn-sm mod_confscheduler-run-autoscheduler">
                {{#str}} autoschedulerrun, mod_confscheduler {{/str}}
            </button>
            {{/canmanage}}
            <label class="mx-2 mb-0" for="mod_confscheduler-day-select">{{#str}} day, mod_confscheduler {{/str}}</label>
            <select id="mod_confscheduler-day-select" class="mod_confscheduler-day-select form-control form-control-sm" hidden></select>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm mod_confscheduler-fullscreen-toggle" aria-pressed="false">
            {{#str}} fullscreen, mod_confscheduler {{/str}}
        </button>
    </div>
    <div class="mod_confscheduler-body">
        {{#canmanage}}
        <div class="mod_confscheduler-unscheduled-panel">
            <h3>{{#str}} unscheduledheading, mod_confscheduler {{/str}}</h3>
            <div class="mod_confscheduler-unscheduled-list" role="list" aria-label="{{#str}} unscheduledheading, mod_confscheduler {{/str}}"></div>
        </div>
        {{/canmanage}}
        <div class="mod_confscheduler-grid-scroll">
            <div class="mod_confscheduler-grid" role="table" aria-label="{{#str}} pluginname, mod_confscheduler {{/str}}"></div>
        </div>
    </div>
</div>
