{{!
    @template mod_confscheduler/addtocontainer_form

    Modal body for the "+" button on a container span block: picks one
    accepted-but-unscheduled submission (from the already-fetched
    state.unscheduled, no separate AJAX call) to nest inside it.

    Context variables required for this template:
    * containerslotid int - the confscheduler_slot id of the container
    * submissions array - [{submissionid, title, speakers}, ...] currently unscheduled

    Example context (json):
    {
        "containerslotid": 12,
        "submissions": [
            {"submissionid": 5, "title": "A Poster", "speakers": "Jane Doe"}
        ]
    }
}}
<form class="mod_confscheduler-addtocontainer-form">
    <input type="hidden" name="containerslotid" value="{{containerslotid}}">
    <div class="form-group">
        <label for="mod_confscheduler-addtocontainer-submission">{{#str}} addtocontainerpresentation, mod_confscheduler {{/str}}</label>
        <select class="form-control" id="mod_confscheduler-addtocontainer-submission" name="submissionid">
            {{#submissions}}
            <option value="{{submissionid}}">{{title}} — {{speakers}}</option>
            {{/submissions}}
        </select>
    </div>
    {{^submissions}}
    <p>{{#str}} addtocontainernounscheduled, mod_confscheduler {{/str}}</p>
    {{/submissions}}
</form>
