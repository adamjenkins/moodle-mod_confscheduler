{{!
    @template mod_confscheduler/display

    Page shell for the read-only Display-mode schedule grid (Phase 3.5), shown to
    users holding mod/confscheduler:viewschedule but not :manageschedule. Renders
    the container, day selector, "my timetable" toggle, and print controls only;
    all grid data is fetched via AJAX and rendered into the empty
    .mod_confscheduler-grid container by amd/src/scheduler_display.js once the
    page loads, mirroring how templates/grid.mustache works for edit mode.

    Context variables required for this template:
    * cmid int - the confscheduler course-module id
    * confschedulerid int - the confscheduler instance id
    * canfavourite bool - whether the current user may toggle favourites
    * exporturl string - the export.php URL for this instance's ICS "my timetable" download

    Example context (json):
    {
        "cmid": 5,
        "confschedulerid": 3,
        "canfavourite": true,
        "exporturl": "https://example.com/mod/confscheduler/export.php?id=5"
    }
}}
<div id="mod_confscheduler-display-root"
     class="mod_confscheduler-grid-container mod_confscheduler-display"
     data-cmid="{{cmid}}"
     data-confschedulerid="{{confschedulerid}}">
    <div class="mod_confscheduler-toolbar mod_confscheduler-print-toolbar d-flex flex-wrap justify-content-between align-items-center mb-2">
        <div class="mod_confscheduler-toolbar-left d-flex flex-wrap align-items-center">
            <label class="mr-2 mb-0" for="mod_confscheduler-day-select">{{#str}} day, mod_confscheduler {{/str}}</label>
            <select id="mod_confscheduler-day-select" class="mod_confscheduler-day-select form-control form-control-sm mr-3" hidden></select>
            <button type="button" class="btn btn-outline-secondary btn-sm mod_confscheduler-mytimetable-toggle" aria-pressed="false">
                {{#str}} mytimetable, mod_confscheduler {{/str}}
            </button>
            <a href="{{exporturl}}" class="btn btn-outline-secondary btn-sm ml-2">
                {{#str}} exportmytimetable, mod_confscheduler {{/str}}
            </a>
        </div>
        <div class="mod_confscheduler-print-controls d-flex flex-wrap align-items-center">
            <fieldset class="mod_confscheduler-print-colourmode mr-3 mb-0">
                <legend class="sr-only">{{#str}} printcolourmode, mod_confscheduler {{/str}}</legend>
                <label class="mr-2">
                    <input type="radio" name="mod_confscheduler_printcolour" value="colour" checked>
                    {{#str}} printcolour, mod_confscheduler {{/str}}
                </label>
                <label>
                    <input type="radio" name="mod_confscheduler_printcolour" value="bw">
                    {{#str}} printbw, mod_confscheduler {{/str}}
                </label>
            </fieldset>
            <label class="mr-2 mb-0" for="mod_confscheduler-print-papersize">{{#str}} papersize, mod_confscheduler {{/str}}</label>
            <select id="mod_confscheduler-print-papersize" class="mod_confscheduler-print-papersize form-control form-control-sm mr-3">
                <option value="A4" selected>A4</option>
                <option value="A3">A3</option>
                <option value="A2">A2</option>
            </select>
            <fieldset class="mod_confscheduler-print-orientation mr-3 mb-0">
                <legend class="sr-only">{{#str}} orientation, mod_confscheduler {{/str}}</legend>
                <label class="mr-2">
                    <input type="radio" name="mod_confscheduler_printorientation" value="portrait" checked>
                    {{#str}} portrait, mod_confscheduler {{/str}}
                </label>
                <label>
                    <input type="radio" name="mod_confscheduler_printorientation" value="landscape">
                    {{#str}} landscape, mod_confscheduler {{/str}}
                </label>
            </fieldset>
            <button type="button" class="btn btn-secondary btn-sm mod_confscheduler-print-trigger">
                {{#str}} print, mod_confscheduler {{/str}}
            </button>
        </div>
    </div>
    <div class="mod_confscheduler-body">
        <div class="mod_confscheduler-grid-scroll">
            <div class="mod_confscheduler-grid" role="table" aria-label="{{#str}} pluginname, mod_confscheduler {{/str}}"></div>
        </div>
    </div>
</div>
