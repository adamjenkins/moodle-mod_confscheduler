{{!
    @template mod_confscheduler/spanblock_form

    Modal body for creating a column-spanning block (e.g. "Lunch Break" or
    "Plenary"): a labelled slot with no presentation, spanning a contiguous
    range of room columns, picked via start/end room selects rather than
    drag-and-drop.

    Context variables required for this template:
    * rooms array - [{id, name}, ...] in column order, for the start/end room selects

    Example context (json):
    {
        "rooms": [
            {"id": 1, "name": "Main Hall"},
            {"id": 2, "name": "Room B"}
        ]
    }
}}
<form class="mod_confscheduler-spanblock-form">
    <div class="form-group">
        <label for="mod_confscheduler-spanblock-label">{{#str}} spanblocklabel, mod_confscheduler {{/str}}</label>
        <input type="text" class="form-control" id="mod_confscheduler-spanblock-label" name="label" required maxlength="255">
    </div>
    <div class="form-row">
        <div class="form-group col">
            <label for="mod_confscheduler-spanblock-startroom">{{#str}} spanblockstartroom, mod_confscheduler {{/str}}</label>
            <select class="form-control" id="mod_confscheduler-spanblock-startroom" name="startroom">
                {{#rooms}}
                <option value="{{id}}">{{name}}</option>
                {{/rooms}}
            </select>
        </div>
        <div class="form-group col">
            <label for="mod_confscheduler-spanblock-endroom">{{#str}} spanblockendroom, mod_confscheduler {{/str}}</label>
            <select class="form-control" id="mod_confscheduler-spanblock-endroom" name="endroom">
                {{#rooms}}
                <option value="{{id}}">{{name}}</option>
                {{/rooms}}
            </select>
        </div>
    </div>
    <div class="form-row">
        <div class="form-group col">
            <label for="mod_confscheduler-spanblock-start">{{#str}} spanblockstart, mod_confscheduler {{/str}}</label>
            <input type="datetime-local" class="form-control" id="mod_confscheduler-spanblock-start" name="starttime" required>
        </div>
        <div class="form-group col">
            <label for="mod_confscheduler-spanblock-end">{{#str}} spanblockend, mod_confscheduler {{/str}}</label>
            <input type="datetime-local" class="form-control" id="mod_confscheduler-spanblock-end" name="endtime" required>
        </div>
    </div>
</form>
