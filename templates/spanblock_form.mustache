{{!
    @template mod_confscheduler/spanblock_form

    Modal body for creating OR editing a column-spanning block (e.g. "Lunch
    Break" or "Plenary"): a labelled slot with no presentation, spanning a
    contiguous range of room columns, picked via start/end room selects
    rather than drag-and-drop. Used for both actions; slotid is present
    (and js reads it to decide add vs. update) only when editing.

    Context variables required for this template:
    * slotid int|string - the confscheduler_slot id, when editing an existing span block (empty string when adding)
    * label string - the current label (empty when adding)
    * colour string|null - the current hex colour, or null
    * starttime string - a datetime-local value (YYYY-MM-DDTHH:mm), or empty when adding
    * endtime string - a datetime-local value (YYYY-MM-DDTHH:mm), or empty when adding
    * rooms array - [{id, name, startselected, endselected}, ...] in column order, for the start/end room selects

    Example context (json):
    {
        "slotid": 7,
        "label": "Lunch Break",
        "colour": "#3366cc",
        "starttime": "2026-09-01T12:00",
        "endtime": "2026-09-01T13:00",
        "rooms": [
            {"id": 1, "name": "Main Hall", "startselected": true, "endselected": false},
            {"id": 2, "name": "Room B", "startselected": false, "endselected": true}
        ]
    }
}}
<form class="mod_confscheduler-spanblock-form">
    <input type="hidden" name="slotid" value="{{slotid}}">
    <div class="form-group">
        <label for="mod_confscheduler-spanblock-label">{{#str}} spanblocklabel, mod_confscheduler {{/str}}</label>
        <input type="text" class="form-control" id="mod_confscheduler-spanblock-label" name="label" required maxlength="255" value="{{label}}">
    </div>
    <div class="form-row">
        <div class="form-group col">
            <label for="mod_confscheduler-spanblock-startroom">{{#str}} spanblockstartroom, mod_confscheduler {{/str}}</label>
            <select class="form-control" id="mod_confscheduler-spanblock-startroom" name="startroom">
                {{#rooms}}
                <option value="{{id}}" {{#startselected}}selected{{/startselected}}>{{name}}</option>
                {{/rooms}}
            </select>
        </div>
        <div class="form-group col">
            <label for="mod_confscheduler-spanblock-endroom">{{#str}} spanblockendroom, mod_confscheduler {{/str}}</label>
            <select class="form-control" id="mod_confscheduler-spanblock-endroom" name="endroom">
                {{#rooms}}
                <option value="{{id}}" {{#endselected}}selected{{/endselected}}>{{name}}</option>
                {{/rooms}}
            </select>
        </div>
    </div>
    <div class="form-row">
        <div class="form-group col">
            <label for="mod_confscheduler-spanblock-start">{{#str}} spanblockstart, mod_confscheduler {{/str}}</label>
            <input type="datetime-local" class="form-control" id="mod_confscheduler-spanblock-start" name="starttime" required value="{{starttime}}">
        </div>
        <div class="form-group col">
            <label for="mod_confscheduler-spanblock-end">{{#str}} spanblockend, mod_confscheduler {{/str}}</label>
            <input type="datetime-local" class="form-control" id="mod_confscheduler-spanblock-end" name="endtime" required value="{{endtime}}">
        </div>
    </div>
    <div class="form-group">
        <label for="mod_confscheduler-spanblock-colour">{{#str}} spanblockcolour, mod_confscheduler {{/str}}</label>
        <input type="color" class="form-control form-control-color" id="mod_confscheduler-spanblock-colour" name="colour" value="{{#colour}}{{colour}}{{/colour}}{{^colour}}#3366cc{{/colour}}">
        <div class="form-check mt-1">
            <input type="checkbox" class="form-check-input" id="mod_confscheduler-spanblock-nocolour" name="nocolour" {{^colour}}checked{{/colour}}>
            <label class="form-check-label" for="mod_confscheduler-spanblock-nocolour">{{#str}} nocolour, mod_confscheduler {{/str}}</label>
        </div>
    </div>
</form>
