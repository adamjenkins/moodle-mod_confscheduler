{{!
    @template mod_confscheduler/autoscheduler_form

    Modal body for running the autoscheduler: a time window, a default
    duration applied to every submission it places, and a "clear first"
    checkbox (unchecked by default, per the Phase 3.4 spec).

    Context variables required for this template: none.

    Example context (json):
    {}
}}
<form class="mod_confscheduler-autoscheduler-form">
    <div class="form-row">
        <div class="form-group col">
            <label for="mod_confscheduler-autoscheduler-windowstart">{{#str}} autoschedulerwindowstart, mod_confscheduler {{/str}}</label>
            <input type="datetime-local" class="form-control" id="mod_confscheduler-autoscheduler-windowstart" name="windowstart" required>
        </div>
        <div class="form-group col">
            <label for="mod_confscheduler-autoscheduler-windowend">{{#str}} autoschedulerwindowend, mod_confscheduler {{/str}}</label>
            <input type="datetime-local" class="form-control" id="mod_confscheduler-autoscheduler-windowend" name="windowend" required>
        </div>
    </div>
    <div class="form-group">
        <label for="mod_confscheduler-autoscheduler-duration">{{#str}} autoschedulerdefaultduration, mod_confscheduler {{/str}}</label>
        <input type="number" class="form-control" id="mod_confscheduler-autoscheduler-duration" name="defaultdurationminutes" min="1" step="1" value="30" required>
    </div>
    <div class="form-check">
        <input type="checkbox" class="form-check-input" id="mod_confscheduler-autoscheduler-clearfirst" name="clearfirst">
        <label class="form-check-label" for="mod_confscheduler-autoscheduler-clearfirst">{{#str}} autoschedulerclearfirst, mod_confscheduler {{/str}}</label>
    </div>
</form>
